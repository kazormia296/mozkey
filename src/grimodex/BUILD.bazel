    hdrs = ["consumer_runtime_capability.h"],
    deps = ["@com_google_absl//absl/strings:string_view"],
)

mozc_cc_library(
    name = "consumer_file_registrar_posix",
    srcs = ["consumer_file_registrar_posix.cc"],
    hdrs = ["consumer_file_registrar_posix.h"],
    tags = [
        "noandroid",
        "nowin",
    ],
    deps = [
        ":consumer_file_registrar",
        ":consumer_handshake",
        "@com_google_absl//absl/status",
        "@com_google_absl//absl/status:statusor",
        "@com_google_absl//absl/strings",
        "@com_google_absl//absl/strings:string_view",
    ],
)

mozc_cc_library(
    name = "consumer_file_registrar_windows",
    srcs = ["consumer_file_registrar_windows.cc"],
    hdrs = ["consumer_file_registrar_windows.h"],
    linkopts = select({
        "@platforms//os:windows": ["Advapi32.lib"],
        "//conditions:default": [],
    }),
    tags = MOZC_TAGS.WIN_ONLY,
    target_compatible_with = ["@platforms//os:windows"],
    deps = [
        ":consumer_file_registrar",
        ":consumer_handshake",
        ":protocol_v1_windows_secure_reader",
        "@com_google_absl//absl/status",
        "@com_google_absl//absl/status:statusor",
        "@com_google_absl//absl/strings",
        "@com_google_absl//absl/strings:string_view",
    ],
)

mozc_cc_library(
    name = "desktop_consumer_heartbeat",
    srcs = ["desktop_consumer_heartbeat.cc"],
    hdrs = ["desktop_consumer_heartbeat.h"],
    deps = [
        ":consumer_file_registrar",
        ":consumer_handshake",
        ":consumer_heartbeat",
        "//base:environ",
        "//base:thread",
        "//base:version",
        "@com_google_absl//absl/log",
        "@com_google_absl//absl/status",
        "@com_google_absl//absl/status:statusor",
        "@com_google_absl//absl/synchronization",
        "@com_google_absl//absl/time",
    ] + mozc_select(
        macos = [
            ":consumer_file_registrar_posix",
            ":protocol_v1_secure_reader",
        ],
        windows = [
            ":consumer_file_registrar_windows",
            ":consumer_runtime_capability",
            ":protocol_v1_windows_secure_reader",
            "//base:file_util",
            "//base:system_util",
            "//base/win32:wide_char",
        ],
    ),
)

mozc_cc_library(
    name = "protocol_v1",
    srcs = ["protocol_v1.cc"],
    hdrs = ["protocol_v1.h"],
    deps = [
        ":protocol_v1_cc_proto",
        "@com_google_absl//absl/status",
        "@com_google_absl//absl/status:statusor",
        "@com_google_absl//absl/strings:string_view",
