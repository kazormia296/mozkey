load("@com_google_protobuf//bazel:cc_proto_library.bzl", "cc_proto_library")
load("@com_google_protobuf//bazel:proto_library.bzl", "proto_library")
load(
    "//:build_defs.bzl",
    "MOZC_TAGS",
    "mozc_cc_library",
    "mozc_cc_test",
    "mozc_select",
)

package(default_visibility = ["//:__subpackages__"])

proto_library(
    name = "protocol_v1_proto",
    srcs = ["protocol_v1.proto"],
    deps = ["@com_google_protobuf//:struct_proto"],
)

cc_proto_library(
    name = "protocol_v1_cc_proto",
    deps = [":protocol_v1_proto"],
)

mozc_cc_library(
    name = "client_context",
    srcs = ["client_context.cc"],
    hdrs = ["client_context.h"],
    deps = ["//protocol:commands_cc_proto"],
)

mozc_cc_library(
    name = "consumer_handshake",
    srcs = ["consumer_handshake.cc"],
    hdrs = ["consumer_handshake.h"],
    deps = [
        "@com_google_absl//absl/status",
        "@com_google_absl//absl/status:statusor",
        "@com_google_absl//absl/strings",
        "@com_google_absl//absl/strings:string_view",
        "@com_google_absl//absl/time",
    ],
)

mozc_cc_library(
    name = "consumer_file_registrar",
    hdrs = ["consumer_file_registrar.h"],
    deps = [
        ":consumer_handshake",
        "@com_google_absl//absl/status",
        "@com_google_absl//absl/strings:string_view",
    ],
)

mozc_cc_library(
    name = "consumer_heartbeat",
    srcs = ["consumer_heartbeat.cc"],
    hdrs = ["consumer_heartbeat.h"],
    deps = [
        ":consumer_file_registrar",
        ":consumer_handshake",
        "@com_google_absl//absl/status",
        "@com_google_absl//absl/time",
    ],
)

mozc_cc_library(
    name = "consumer_runtime_capability",
