#!/bin/sh

# Build a Fedora/RPM x86_64 package from the attested Fedora payload.
set -eu
umask 022

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)"
repository_root="$(CDPATH= cd -- "${script_dir}/.." && pwd -P)"
output_dir="${MOZKEY_LINUX_OUTPUT_DIR:-${repository_root}/dist}"

if [ "$#" -ne 0 ]; then
  echo "usage: $0" >&2
  exit 2
fi
case "${output_dir}" in
  /*) ;;
  *) echo "MOZKEY_LINUX_OUTPUT_DIR must be absolute" >&2; exit 2 ;;
esac
for command in cpio git install python3 rpm rpm2cpio rpmbuild tar
do
  command -v "${command}" >/dev/null 2>&1 || {
    echo "required RPM package command is unavailable: ${command}" >&2
    exit 1
  }
done
os_release_id="$(sed -n 's/^ID=//p' /etc/os-release 2>/dev/null |
  sed -n '1p' | tr -d "\"'")"
if [ "${os_release_id}" != fedora ] &&
   [ "${MOZKEY_LINUX_ALLOW_NON_FEDORA_FOR_TESTS:-}" != 1 ]; then
  echo "RPM packaging requires a Fedora build host" >&2
  exit 1
fi

version="$(sed -n \
  -e 's/^MOZKEY_RELEASE_VERSION_MAJOR = //p' \
  -e 's/^MOZKEY_RELEASE_VERSION_MINOR = //p' \
  -e 's/^MOZKEY_RELEASE_VERSION_PATCH = //p' \
  "${repository_root}/src/version.bzl" | paste -sd . -)"
printf '%s\n' "${version}" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+$' || exit 1
source_date_epoch="${SOURCE_DATE_EPOCH:-$(git -C "${repository_root}" log -1 --format=%ct)}"
case "${source_date_epoch}" in
  ''|*[!0-9]*) echo "SOURCE_DATE_EPOCH must be a non-negative integer" >&2; exit 2 ;;
esac
export SOURCE_DATE_EPOCH="${source_date_epoch}"

stage_dir="$(mktemp -d "${TMPDIR:-/tmp}/mozkey-rpm-stage.XXXXXX")"
rpm_root="$(mktemp -d "${TMPDIR:-/tmp}/mozkey-rpm-work.XXXXXX")"
extract_dir="$(mktemp -d "${TMPDIR:-/tmp}/mozkey-rpm-extract.XXXXXX")"
cleanup() {
  rm -rf "${stage_dir}" "${rpm_root}" "${extract_dir}"
}
trap cleanup EXIT HUP INT TERM
mkdir -p "${rpm_root}/BUILD" "${rpm_root}/BUILDROOT" "${rpm_root}/RPMS" \
  "${rpm_root}/SOURCES" "${rpm_root}/SPECS" "${rpm_root}/SRPMS"

"${script_dir}/stage_mozkey_linux_native_package" fedora-x86_64 "${stage_dir}"
find "${stage_dir}" -depth -exec touch -h -d "@${source_date_epoch}" {} +
tar --format=gnu --sort=name --owner=0 --group=0 --numeric-owner \
  --mtime="@${source_date_epoch}" -C "${stage_dir}" \
  -czf "${rpm_root}/SOURCES/mozkey-ibg-${version}.tar.gz" usr

cat > "${rpm_root}/SPECS/mozkey-ibg.spec" <<EOF
%global debug_package %{nil}
%global __os_install_post %{nil}
Name:           mozkey-ibg
Version:        ${version}
Release:        1%{?dist}
Summary:        Mozkey Japanese input method integrated with Grimodex
License:        BSD-3-Clause AND Apache-2.0 AND LGPL-2.1-or-later AND MIT
URL:            https://github.com/kazormia296/mozkey
Source0:        %{name}-%{version}.tar.gz
BuildArch:      x86_64
Requires:       fcitx5 >= 5.1.0

%description
Mozkey IbG is an Fcitx5 Japanese input method with local Zenz correction
and a secure Grimodex desktop dictionary integration.

%prep
%setup -q -c -T
tar -xzf %{SOURCE0}

%install
rm -rf %{buildroot}
mkdir -p %{buildroot}
cp -a usr %{buildroot}/

%files
/usr/lib/mozkey
/usr/lib64/fcitx5/fcitx5-mozkey.so
%doc /usr/share/doc/mozkey
/usr/share/fcitx5
/usr/share/icons/hicolor
%license /usr/share/licenses/mozkey
/usr/share/locale
/usr/share/metainfo/org.fcitx.Fcitx5.Addon.Mozkey.metainfo.xml
/usr/share/mozkey

%changelog
* Thu Jan 01 1970 kazormia296 <kazormia296@users.noreply.github.com> - ${version}-1
- Automated Mozkey IbG release build
EOF

rpmbuild --define "_topdir ${rpm_root}" \
  --define "_source_date_epoch ${source_date_epoch}" \
  -bb "${rpm_root}/SPECS/mozkey-ibg.spec"
set -- "${rpm_root}"/RPMS/x86_64/mozkey-ibg-"${version}"-1.*.x86_64.rpm
if [ "$#" -ne 1 ] || [ ! -f "$1" ]; then
  echo "expected exactly one Mozkey RPM" >&2
  exit 1
fi
package="$1"
[ "$(rpm -qp --qf '%{NAME}' "${package}")" = mozkey-ibg ]
[ "$(rpm -qp --qf '%{VERSION}' "${package}")" = "${version}" ]
[ "$(rpm -qp --qf '%{ARCH}' "${package}")" = x86_64 ]
rpm -qpl "${package}" | grep -Fq '/usr/lib/mozkey/llama-server'
rpm -qpR "${package}" | grep -Eq '^fcitx5([[:space:]]|$)'
rpm -qp --licensefiles "${package}" |
  grep -Fq '/usr/share/licenses/mozkey/zenz-runtime/llama.cpp-MIT.txt'
(
  cd "${extract_dir}"
  rpm2cpio "${package}" | cpio -idm --quiet --no-absolute-filenames
)
python3 "${repository_root}/tools/release/verify_staged_linux_payload.py" \
  "${stage_dir}/usr" "${extract_dir}/usr"

install -d -m 755 "${output_dir}"
install -m 644 "${package}" "${output_dir}/mozkey-ibg-${version}-1.x86_64.rpm"
install -m 644 \
  "${repository_root}/dist/linux/fedora-x86_64/build-attestation.json" \
  "${output_dir}/mozkey-v${version}-fedora-x86_64.build-attestation.json"
install -m 644 "${stage_dir}/usr/share/doc/mozkey/mozkey-linux.spdx.json" \
  "${output_dir}/mozkey-v${version}-fedora-x86_64.spdx.json"
printf 'Mozkey RPM package: %s\n' \
  "${output_dir}/mozkey-ibg-${version}-1.x86_64.rpm"
