#!/bin/sh

set -eu

PREFIX="${PREFIX:-/usr}"
DESTDIR="${DESTDIR:-}"
script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)"
. "${script_dir}/fcitx5_install_paths"
validate_mozkey_install_environment
ICON_DIR="${DESTDIR}${PREFIX}/share/icons/hicolor"

install -D -m 644 data/images/product_icon_32bpp-128.png "${ICON_DIR}/128x128/apps/org.fcitx.Fcitx5.fcitx_mozkey.png"
install -D -m 644 data/images/unix/ime_product_icon_opensource-32.png "${ICON_DIR}/32x32/apps/org.fcitx.Fcitx5.fcitx_mozkey.png"
install -D -m 644 ../scripts/icons/ui-alpha_full.png "${ICON_DIR}/48x48/apps/org.fcitx.Fcitx5.fcitx_mozkey_alpha_full.png"
install -D -m 644 ../scripts/icons/ui-alpha_half.png "${ICON_DIR}/48x48/apps/org.fcitx.Fcitx5.fcitx_mozkey_alpha_half.png"
install -D -m 644 ../scripts/icons/ui-direct.png "${ICON_DIR}/48x48/apps/org.fcitx.Fcitx5.fcitx_mozkey_direct.png"
install -D -m 644 ../scripts/icons/ui-hiragana.png "${ICON_DIR}/48x48/apps/org.fcitx.Fcitx5.fcitx_mozkey_hiragana.png"
install -D -m 644 ../scripts/icons/ui-katakana_full.png "${ICON_DIR}/48x48/apps/org.fcitx.Fcitx5.fcitx_mozkey_katakana_full.png"
install -D -m 644 ../scripts/icons/ui-katakana_half.png "${ICON_DIR}/48x48/apps/org.fcitx.Fcitx5.fcitx_mozkey_katakana_half.png"
install -D -m 644 ../scripts/icons/ui-dictionary.png "${ICON_DIR}/48x48/apps/org.fcitx.Fcitx5.fcitx_mozkey_dictionary.png"
install -D -m 644 ../scripts/icons/ui-properties.png "${ICON_DIR}/48x48/apps/org.fcitx.Fcitx5.fcitx_mozkey_properties.png"
install -D -m 644 ../scripts/icons/ui-tool.png "${ICON_DIR}/48x48/apps/org.fcitx.Fcitx5.fcitx_mozkey_tool.png"

ln -sf org.fcitx.Fcitx5.fcitx_mozkey.png "${ICON_DIR}/128x128/apps/fcitx_mozkey.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey.png "${ICON_DIR}/32x32/apps/fcitx_mozkey.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey_alpha_full.png "${ICON_DIR}/48x48/apps/fcitx_mozkey_alpha_full.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey_alpha_half.png "${ICON_DIR}/48x48/apps/fcitx_mozkey_alpha_half.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey_direct.png "${ICON_DIR}/48x48/apps/fcitx_mozkey_direct.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey_hiragana.png "${ICON_DIR}/48x48/apps/fcitx_mozkey_hiragana.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey_katakana_full.png "${ICON_DIR}/48x48/apps/fcitx_mozkey_katakana_full.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey_katakana_half.png "${ICON_DIR}/48x48/apps/fcitx_mozkey_katakana_half.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey_dictionary.png "${ICON_DIR}/48x48/apps/fcitx_mozkey_dictionary.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey_properties.png "${ICON_DIR}/48x48/apps/fcitx_mozkey_properties.png"
ln -sf org.fcitx.Fcitx5.fcitx_mozkey_tool.png "${ICON_DIR}/48x48/apps/fcitx_mozkey_tool.png"
